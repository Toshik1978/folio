APP_ENV=development
PORT=8080
DATA_DIR=./data
# Canonical external base URL (e.g. https://folio.example.com). Optional; set it
# behind a reverse proxy / Cloudflare tunnel so the OPDS OpenSearch URL is built
# from a trusted host instead of a forgeable X-Forwarded-Host. Leave empty for
# local/direct access.
PUBLIC_URL=
# Google Books API key
GOOGLE_KEY=
# Optional defense-in-depth: confine every library path to this base directory.
# When set, the API refuses to create or edit a library whose path resolves
# outside it, so an admin (or a stolen admin session) cannot point a library at
# an arbitrary host path like /etc and serve files back out. Leave empty (the
# default) to allow any host path. In a container, set it to your books mount.
LIBRARY_ROOT=
